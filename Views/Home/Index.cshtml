@model CyberWatchAnalytics.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Panel Principal";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Panel Principal</h2>
            <p class="text-muted mb-0">
                Resumen general de CyberWatch Analytics.
            </p>
        </div>
    </div>

    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Usuarios</h5>
                    <h2>@Model.TotalUsuarios</h2>
                    <p class="text-muted mb-0">Registrados</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Activos</h5>
                    <h2>@Model.TotalActivos</h2>
                    <p class="text-muted mb-0">Tecnológicos</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Incidentes</h5>
                    <h2>@Model.TotalIncidentes</h2>
                    <p class="text-muted mb-0">Registrados</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h5 class="card-title">Vulnerabilidades</h5>
                    <h2>@Model.TotalVulnerabilidades</h2>
                    <p class="text-muted mb-0">Detectadas</p>
                </div>
            </div>
        </div>

    </div>

    <div class="row">

        <div class="col-lg-6 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white">
                    <strong>Últimos incidentes</strong>
                </div>

                <div class="card-body">

                    @if (Model.UltimosIncidentes.Any())
                    {
                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Título</th>
                                    <th>Activo</th>
                                    <th>Criticidad</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var incidente in Model.UltimosIncidentes)
                                {
                                    <tr>
                                        <td>@incidente.Titulo</td>
                                        <td>@incidente.IdActivoNavigation.NombreActivo</td>
                                        <td>@incidente.Criticidad</td>
                                    </tr>
                                }

                            </tbody>

                        </table>
                    }
                    else
                    {
                        <p class="text-muted mb-0">
                            No existen incidentes registrados.
                        </p>
                    }

                </div>

            </div>

        </div>

        <div class="col-lg-6 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white">
                    <strong>Últimas vulnerabilidades</strong>
                </div>

                <div class="card-body">

                    @if (Model.UltimasVulnerabilidades.Any())
                    {
                        <table class="table table-hover align-middle mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Activo</th>
                                    <th>Severidad</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var vulnerabilidad in Model.UltimasVulnerabilidades)
                                {
                                    <tr>
                                        <td>@vulnerabilidad.IdActivoNavigation.NombreActivo</td>
                                        <td>@vulnerabilidad.Severidad</td>
                                        <td>@vulnerabilidad.EstadoMitigacion</td>
                                    </tr>
                                }

                            </tbody>

                        </table>
                    }
                    else
                    {
                        <p class="text-muted mb-0">
                            No existen vulnerabilidades registradas.
                        </p>
                    }

                </div>

            </div>

        </div>

    </div>

</div>