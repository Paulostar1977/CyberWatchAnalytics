<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CyberWatch Analytics</title>

        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <div class="d-flex min-vh-100">

        <aside class="sidebar">

            <div class="sidebar-title">
                CyberWatch<br />
                <span>Analytics</span>
            </div>

            <nav class="sidebar-menu">

                <a asp-controller="Home"
                   asp-action="Index">
                    Dashboard
                </a>

                @if (Context.Session.GetString("RolUsuario") == "Administrador")
                {
                    <a asp-controller="Usuarios"
                       asp-action="Index">
                        Usuarios
                    </a>
                }

                <a asp-controller="Activos"
                   asp-action="Index">
                    Activos Tecnológicos
                </a>

                <a asp-controller="Incidentes"
                   asp-action="Index">
                    Incidentes
                </a>

                <a asp-controller="Vulnerabilidades"
                   asp-action="Index">
                    Vulnerabilidades
                </a>

                <a asp-controller="Reportes"
                    asp-action="Index">
                    Reportes
                </a>

            </nav>

        </aside>

        <div class="main-content flex-grow-1">

            <header class="topbar">

                <div>
                    <strong>@ViewData["Title"]</strong>
                </div>

                <div class="d-flex align-items-center gap-3">

                    <div class="text-end">

                        <div class="fw-semibold">
                            @Context.Session.GetString("NombreUsuario")
                        </div>

                        <div class="text-muted small">
                            @Context.Session.GetString("RolUsuario")
                        </div>

                    </div>

                    <a asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-outline-secondary btn-sm">
                        Cerrar sesión
                    </a>

                </div>

            </header>

            <main class="content-wrapper">
                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>