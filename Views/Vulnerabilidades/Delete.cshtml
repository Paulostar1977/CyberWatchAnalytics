@model CyberWatchAnalytics.Models.Vulnerabilidad

@{
    ViewData["Title"] = "Eliminar Vulnerabilidad";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Eliminar Vulnerabilidad</h2>
            <p class="text-muted mb-0">
                Confirme la eliminación de la vulnerabilidad seleccionada.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="alert alert-warning">
                Esta acción eliminará permanentemente la vulnerabilidad.
            </div>

            <dl class="row mb-4">

                <dt class="col-sm-3">Activo tecnológico</dt>
                <dd class="col-sm-9">
                    @Model.IdActivoNavigation.NombreActivo
                </dd>

                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@Model.Descripcion</dd>

                <dt class="col-sm-3">Severidad</dt>
                <dd class="col-sm-9">@Model.Severidad</dd>

                <dt class="col-sm-3">Estado de mitigación</dt>
                <dd class="col-sm-9">@Model.EstadoMitigacion</dd>

                <dt class="col-sm-3">Fecha de detección</dt>
                <dd class="col-sm-9">
                    @Model.FechaDeteccion.ToString("dd-MM-yyyy")
                </dd>

            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="IdVulnerabilidad" />

                <button type="submit" class="btn btn-danger">
                    Confirmar eliminación
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>
            </form>

        </div>
    </div>

</div>