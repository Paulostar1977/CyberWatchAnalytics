@model CyberWatchAnalytics.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión - CyberWatch Analytics</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="login-page">
    <div class="login-container">
        <div class="login-card shadow">
            <div class="text-center mb-4">
                <h2 class="login-title">CyberWatch</h2>
                <h4 class="login-subtitle">Analytics</h4>
                <p class="text-muted mt-3">Gestión de seguridad informática</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model?.MensajeError))
            {
                <div class="alert alert-danger">
                    @Model.MensajeError
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="Correo" class="form-label">Correo electrónico</label>
                    <input asp-for="Correo"
                           class="form-control"
                           placeholder="admin@cyberwatch.cl"
                           autocomplete="email" />
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           placeholder="Ingrese su contraseña"
                           autocomplete="current-password" />
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Iniciar sesión
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>