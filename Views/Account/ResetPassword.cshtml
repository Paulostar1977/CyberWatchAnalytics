@model CyberWatchAnalytics.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Restablecer contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Restablecer contraseña - CyberWatch Analytics</title>

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body class="login-page">

    <div class="login-container">

        <div class="login-card shadow">

            <div class="text-center mb-4">
                <h2 class="login-title">CyberWatch</h2>
                <h4 class="login-subtitle">Analytics</h4>

                <p class="text-muted mt-3 mb-0">
                    Restablecer contraseña
                </p>
            </div>

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success">
                    @TempData["MensajeExito"]
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
            {
                <div class="alert alert-danger">
                    @Model.MensajeError
                </div>
            }

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <form asp-controller="Account"
                  asp-action="ResetPassword"
                  method="post">

                <div class="mb-3">

                    <label asp-for="Correo"
                           class="form-label">
                    </label>

                    <input asp-for="Correo"
                           class="form-control"
                           autocomplete="email" />

                    <span asp-validation-for="Correo"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Codigo"
                           class="form-label">
                    </label>

                    <input asp-for="Codigo"
                           class="form-control"
                           placeholder="Código de 6 dígitos"
                           maxlength="6"
                           autocomplete="one-time-code" />

                    <span asp-validation-for="Codigo"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="NuevaPassword"
                           class="form-label">
                    </label>

                    <input asp-for="NuevaPassword"
                           class="form-control"
                           autocomplete="new-password" />

                    <span asp-validation-for="NuevaPassword"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-4">

                    <label asp-for="ConfirmarPassword"
                           class="form-label">
                    </label>

                    <input asp-for="ConfirmarPassword"
                           class="form-control"
                           autocomplete="new-password" />

                    <span asp-validation-for="ConfirmarPassword"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn btn-primary w-100">
                    Guardar nueva contraseña
                </button>

            </form>

            <div class="text-center mt-4">

                <a asp-controller="Account"
                   asp-action="ForgotPassword">
                    Solicitar un código nuevo
                </a>

            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    
</body>
</html>