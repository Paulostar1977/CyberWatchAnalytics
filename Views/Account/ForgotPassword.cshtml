@model CyberWatchAnalytics.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Recuperar contraseña - CyberWatch Analytics</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body class="login-page">

    <div class="login-container">

        <div class="login-card shadow">

            <div class="text-center mb-4">
                <h2 class="login-title">CyberWatch</h2>
                <h4 class="login-subtitle">Analytics</h4>

                <p class="text-muted mt-3 mb-0">
                    Recuperación de contraseña
                </p>
            </div>

            <p class="text-muted">
                Ingrese el correo electrónico registrado en el sistema.
                Recibirá un código con una vigencia de 15 minutos.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.Mensaje))
            {
                <div class="alert alert-success">
                    @Model.Mensaje
                </div>
            }

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <form asp-controller="Account"
                  asp-action="ForgotPassword"
                  method="post">

                <div class="mb-4">

                    <label asp-for="Correo"
                           class="form-label">
                    </label>

                    <input asp-for="Correo"
                           class="form-control"
                           placeholder="usuario@correo.com"
                           autocomplete="email" />

                    <span asp-validation-for="Correo"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn btn-primary w-100">
                    Enviar código
                </button>

            </form>

            <div class="text-center mt-4">

                <a asp-controller="Account"
                   asp-action="Login">
                    Volver al inicio de sesión
                </a>

            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>