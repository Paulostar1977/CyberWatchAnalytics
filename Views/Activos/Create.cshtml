@model CyberWatchAnalytics.ViewModels.ActivoCreateViewModel

@{
    ViewData["Title"] = "Nuevo Activo";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Nuevo Activo Tecnológico</h2>
            <p class="text-muted mb-0">
                Complete la información para registrar un nuevo activo.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="NombreActivo" class="form-label"></label>
                        <input asp-for="NombreActivo" class="form-control" />
                        <span asp-validation-for="NombreActivo"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DireccionIp" class="form-label"></label>
                        <input asp-for="DireccionIp"
                               class="form-control"
                               placeholder="Ejemplo: 192.168.1.10" />
                        <span asp-validation-for="DireccionIp"
                              class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Ubicacion" class="form-label"></label>
                        <input asp-for="Ubicacion" class="form-control" />
                        <span asp-validation-for="Ubicacion"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="IdTipoActivo" class="form-label"></label>

                        <select asp-for="IdTipoActivo"
                                asp-items="Model.Tipos"
                                class="form-select">
                            <option value="">Seleccione...</option>
                        </select>

                        <span asp-validation-for="IdTipoActivo"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Estado" class="form-label"></label>

                        <select asp-for="Estado" class="form-select">
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                            <option value="En mantenimiento">En mantenimiento</option>
                        </select>

                        <span asp-validation-for="Estado"
                              class="text-danger"></span>
                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-primary">
                    Guardar Activo
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}