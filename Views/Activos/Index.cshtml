@model IEnumerable<CyberWatchAnalytics.Models.ActivosTecnologico>

@{
    ViewData["Title"] = "Activos Tecnológicos";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Activos Tecnológicos</h2>
            <p class="text-muted mb-0">
                Administración de los activos tecnológicos registrados.
            </p>
        </div>

        <a asp-controller="Activos"
           asp-action="Create"
           class="btn btn-primary">
            Nuevo Activo
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Dirección IP</th>
                            <th>Tipo</th>
                            <th>Ubicación</th>
                            <th>Estado</th>
                            <th>Fecha de registro</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var activo in Model)
                        {
                            <tr>
                                <td>@activo.NombreActivo</td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(activo.DireccionIp)
                                        ? "Sin asignar"
                                        : activo.DireccionIp)
                                </td>

                                <td>
                                    @activo.IdTipoActivoNavigation.NombreTipo
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(activo.Ubicacion)
                                        ? "Sin especificar"
                                        : activo.Ubicacion)
                                </td>

                                <td>
                                    @if (activo.Estado == "Activo")
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            @activo.Estado
                                        </span>
                                    }
                                </td>

                                <td>
                                    @activo.FechaRegistro.ToString("dd-MM-yyyy")
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit"
                                       asp-route-id="@activo.IdActivo"
                                       class="btn btn-outline-primary btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@activo.IdActivo"
                                       class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>

</div>