@model CyberWatchAnalytics.ViewModels.UsuarioCreateViewModel

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Nuevo Usuario</h2>
            <p class="text-muted mb-0">
                Complete la información para registrar un nuevo usuario.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="Nombre" class="form-label"></label>

                        <input asp-for="Nombre" class="form-control" />

                        <span asp-validation-for="Nombre" class="text-danger"></span>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label asp-for="Correo" class="form-label"></label>

                        <input asp-for="Correo" class="form-control" />

                        <span asp-validation-for="Correo" class="text-danger"></span>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label asp-for="Password" class="form-label"></label>

                        <input asp-for="Password" class="form-control" />

                        <span asp-validation-for="Password" class="text-danger"></span>

                    </div>

                    <div class="col-md-3 mb-3">

                        <label asp-for="IdRol" class="form-label"></label>

                        <select asp-for="IdRol"
                                asp-items="Model.Roles"
                                class="form-select">
                            <option value="">Seleccione...</option>
                        </select>

                        <span asp-validation-for="IdRol" class="text-danger"></span>

                    </div>

                    <div class="col-md-3 mb-3">

                        <label asp-for="Estado" class="form-label"></label>

                        <select asp-for="Estado" class="form-select">
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>

                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-primary">
                    Guardar Usuario
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}