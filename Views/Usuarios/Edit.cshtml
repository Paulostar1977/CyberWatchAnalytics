@model CyberWatchAnalytics.ViewModels.UsuarioEditViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Editar Usuario</h2>
            <p class="text-muted mb-0">
                Modifique la información del usuario seleccionado.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Edit" method="post">
                <input asp-for="IdUsuario" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" class="form-control" />
                        <span asp-validation-for="Correo"
                              class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password"
                               class="form-control"
                               placeholder="Deje vacío para mantener la contraseña actual" />
                        <span asp-validation-for="Password"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="IdRol" class="form-label">Rol</label>

                        <select asp-for="IdRol"
                                asp-items="Model.Roles"
                                class="form-select">
                            <option value="">Seleccione...</option>
                        </select>

                        <span asp-validation-for="IdRol"
                              class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Estado" class="form-label"></label>

                        <select asp-for="Estado" class="form-select">
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>

                        <span asp-validation-for="Estado"
                              class="text-danger"></span>
                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-primary">
                    Guardar Cambios
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>
            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}