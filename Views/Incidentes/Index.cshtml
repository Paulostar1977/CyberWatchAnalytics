@model IEnumerable<CyberWatchAnalytics.Models.IncidentesSeguridad>

@{
    ViewData["Title"] = "Incidentes de Seguridad";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Incidentes de Seguridad</h2>
            <p class="text-muted mb-0">
                Administración de los incidentes de seguridad registrados.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            Nuevo Incidente
        </a>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">
            @TempData["MensajeExito"]
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MensajeError"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Título</th>
                            <th>Activo</th>
                            <th>Criticidad</th>
                            <th>Estado</th>
                            <th>Fecha de registro</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var incidente in Model)
                        {
                            <tr>
                                <td>@incidente.Titulo</td>
                                <td>@incidente.IdActivoNavigation.NombreActivo</td>

                                <td>
                                    @switch (incidente.Criticidad)
                                    {
                                        case "Crítica":
                                            <span class="badge bg-danger">Crítica</span>
                                            break;

                                        case "Alta":
                                            <span class="badge bg-warning text-dark">Alta</span>
                                            break;

                                        case "Media":
                                            <span class="badge bg-primary">Media</span>
                                            break;

                                        default:
                                            <span class="badge bg-secondary">Baja</span>
                                            break;
                                    }
                                </td>

                                <td>@incidente.Estado</td>

                                <td>
                                    @incidente.FechaRegistro.ToString("dd-MM-yyyy")
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit"
                                       asp-route-id="@incidente.IdIncidente"
                                       class="btn btn-outline-primary btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@incidente.IdIncidente"
                                       class="btn btn-outline-danger btn-sm">
                                        Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>

</div>